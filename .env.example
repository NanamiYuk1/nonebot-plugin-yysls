# 使用本插件前，请将此文件复制并重命名为 .env，然后填入您的实际配置

DRIVER=~fastapi+~websockets
HOST=0.0.0.0
PORT=8080

# ========== NoneBot 基础配置 ==========
# 管理bot的qq账号（一般为您的大号qq）
SUPERUSERS=["您的超级用户QQ号"]
# 唤醒bot的前置指令
COMMAND_START=["/"]

# ========== 燕云十六声插件配置 ==========
# 订阅公告的群号列表，格式：[群号1, 群号2]
YYSLS_SUBSCRIBE_GROUPS=[]

# 公告检查间隔（分钟）
YYSLS_CHECK_INTERVAL=30

# 每月商城提醒日期（1-28之间）
YYSLS_SHOP_REMIND_DAY=1

# 提醒时间（24小时制）
YYSLS_SHOP_REMIND_HOUR=10

# 商城提醒项目名称（可自定义）
# YYSLS_SHOP_ITEMS=["和鸣-地华商店每月限时兑换"]