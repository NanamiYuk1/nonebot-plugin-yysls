# 使用本插件前，请将此文件复制并重命名为 .env，然后填入您的实际配置

DRIVER=~fastapi+~websockets
HOST=0.0.0.0
PORT=8080

# ========== NoneBot 基础配置 ==========
# 管理bot的qq账号（一般为您的大号qq）
SUPERUSERS=["您的超级用户QQ号"]
# 唤醒bot的前置指令
COMMAND_START=["/"]

# ========== 燕云十六声插件配置 ==========
# 订阅公告的群号列表，格式：[群号1, 群号2]
YYSLS_SUBSCRIBE_GROUPS=[]

# 公告检查间隔（分钟）
YYSLS_CHECK_INTERVAL=30

# 每月商城提醒日期（1-28之间）
YYSLS_SHOP_REMIND_DAY=1

# 提醒时间（24小时制）
YYSLS_SHOP_REMIND_HOUR=10

# 商城提醒项目名称（可自定义）
# YYSLS_SHOP_ITEMS=["和鸣-地华商店每月限时兑换"]

# ==============================
# AI 大模型配置 (核心必填)
# ==============================
# 推荐使用 DeepSeek、通义千问 或 OpenAI 兼容接口
# 请前往对应云平台的控制台获取 API Key

# 你的 API 密钥 (请替换为真实的 Key，切勿泄露！)
AI_API_KEY=sk-your_api_key_here

# API 接口的基础 URL (以通义千问/DashScope为例，DeepSeek/OpenAI请替换为对应地址)
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称 (如 qwen-turbo, deepseek-chat, gpt-3.5-turbo 等)
AI_MODEL=qwen-turbo

# B站API配置
# Cookie 获取方式
# 登录 B 站 → F12 打开开发者工具 → Application → Cookies
# 找到 SESSDATA 和 bili_jct 的值
BILIBILI_SESSDATA="您的SESSDATA值"
BILIBILI_BILI_JCT="您的bili_jct值"